# Copy this file to .env.foreman and update the values with your secrets.
DATABASE_URL=postgresql://username:password@db:5432/foreman
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT_SECONDS=30

# Cloudflare R2 Storage
STORAGE_PROVIDER=r2
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=foreman-images
R2_PUBLIC_URL=https://storage.yourdomain.com  # optional

# ── Amazon S3 Storage (alternative to Cloudflare R2) ─────────────────────────
# Set STORAGE_PROVIDER=s3 and provide the variables below.
# Credentials are optional when deploying on AWS with an IAM role/instance profile.
#
# STORAGE_PROVIDER=s3
# S3_BUCKET=foreman-images
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your_access_key_id       # optional if using IAM roles
# S3_SECRET_ACCESS_KEY=your_secret_access_key  # optional if using IAM roles
# S3_PUBLIC_URL=https://cdn.example.com     # optional; use CloudFront or other CDN

# AWS SQS Queue (for background generation processing)
QUEUE_PROVIDER=none  # Options: none, sqs
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/foreman-generations  # Required if QUEUE_PROVIDER=sqs
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
SQS_MAX_RETRIES=3
SQS_DELAY_SECONDS=0

# Worker Configuration
WORKER_CONCURRENCY=1
WORKER_MAX_RETRIES=3
WORKER_POLL_INTERVAL=10
WORKER_VISIBILITY_TIMEOUT=300
WORKER_DEAD_LETTER_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/foreman-generations-dlq
RUNTIME_SESSION_PREFIX=proj

# AI Provider (Google Vertex)
AI_PROVIDER=vertex
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_LOCATION=us-central1
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_ENHANCEMENT_MODEL=gemini-2.0-flash

# AI Provider (AWS AgentCore)
# AI_PROVIDER=agentcore
# AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/my-runtime
# Runtime host output base URL for metadata-only response image links
# RUNTIME_OUTPUT_BASE_URL=https://cdn.example.com/generated
# Optional allowlist of input image hostnames, comma-separated
# RUNTIME_ALLOWED_INPUT_DOMAINS=allowed.example.com,cdn.example.com
# Optional explicit model label returned in response metadata
# RUNTIME_MODEL_USED=us.amazon.nova-pro-v1:0
# Optional Strands Bedrock model id used by runtime summarization calls
# RUNTIME_STRANDS_MODEL_ID=us.amazon.nova-pro-v1:0