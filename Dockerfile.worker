FROM python:3.12-slim

WORKDIR /app

# Copy project files
COPY pyproject.toml .
COPY README.md .
COPY foreman ./foreman
COPY worker ./worker

# Install build dependencies, then install the package
RUN pip install --no-cache-dir setuptools && \
    pip install --no-cache-dir .

# Expose port
EXPOSE 8081

# Run the worker
CMD ["python", "-m", "worker.main"]