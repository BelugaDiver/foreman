meta {
  name: Create Project
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/v1/projects
  body: json
}

headers {
  Content-Type: application/json
  X-User-ID: {{userId}}
}

body:json {
  {
    "name": "My Project",
    "original_image_url": "https://example.com/image.jpg"
  }
}

tests {
  test("should return 201", function() {
    expect(res.status).to.equal(201);
  });
}

script:js {
  if (res.status === 201) {
    bru.setEnvVar("projectId", res.body.id);
  }
}
